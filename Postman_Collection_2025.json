{
  "info": {
    "_postman_id": "correlativos-avales-api",
    "name": "Correlativos Avales Técnicos API",
    "description": "API REST para gestionar avales técnicos con autenticación JWT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "item": [
    {
      "name": "Auth",
      "description": "Endpoints de autenticación",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            },
            "description": "Autenticar usuario y obtener tokens (accessToken + refreshToken)"
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/refresh",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Refrescar accessToken usando refreshToken (expiración 7 días)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/health",
          "host": ["{{BASE_URL}}"],
          "path": ["health"]
        },
        "description": "Verificar salud del servidor (sin autenticación)"
      },
      "response": []
    },
    {
      "name": "Avales",
      "description": "CRUD de avales técnicos",
      "item": [
        {
          "name": "Listar Avales",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/avales?limit=10&offset=0",
              "host": ["{{BASE_URL}}"],
              "path": ["avales"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "solicitante",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "estado",
                  "value": "ACTIVO",
                  "disabled": true
                },
                {
                  "key": "correlativo",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Obtener lista de avales (paginado, filtrable)"
          },
          "response": []
        },
        {
          "name": "Obtener Aval por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/avales/1",
              "host": ["{{BASE_URL}}"],
              "path": ["avales", "1"]
            },
            "description": "Obtener detalles de un aval específico por ID"
          },
          "response": []
        },
        {
          "name": "Crear Aval",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha_registro\": \"2025-02-13\",\n  \"direccion_administrativa\": \"Dirección de Sistemas\",\n  \"unidad_institucion\": \"INSTITUCIÓN A\",\n  \"nombre_solicitante\": \"Juan Pérez\",\n  \"cargo\": \"Analista de Sistemas\",\n  \"fecha_solicitud\": \"2025-02-13\",\n  \"responsable\": \"Carlos García\",\n  \"memorando_solicitud\": \"MEMO-2025-001\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/avales",
              "host": ["{{BASE_URL}}"],
              "path": ["avales"]
            },
            "description": "Crear nuevo aval técnico (requiere rol ADMIN)"
          },
          "response": []
        },
        {
          "name": "Actualizar Aval",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre_solicitante\": \"Juan Pérez Actualizado\",\n  \"cargo\": \"Cordinador de Sistemas\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/avales/1",
              "host": ["{{BASE_URL}}"],
              "path": ["avales", "1"]
            },
            "description": "Actualizar campos específicos de un aval (requiere rol ADMIN)"
          },
          "response": []
        },
        {
          "name": "Anular Aval",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"motivo_anulacion\": \"Solicitud cancelada por el solicitante\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/avales/1/anular",
              "host": ["{{BASE_URL}}"],
              "path": ["avales", "1", "anular"]
            },
            "description": "Anular un aval existente (requiere rol ADMIN)"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    }
  ]
}
