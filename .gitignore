# ===================================================================
# .gitignore - Correlativo Avales Técnicos
# ===================================================================

# ===================================================================
# Node.js / npm
# ===================================================================
node_modules/
npm-debug.log
npm-debug.log*
yarn-error.log
.npm
package-lock.json

# ===================================================================
# Environment Variables (NEVER COMMIT)
# ===================================================================
.env
.env.*
!.env.example
.env.local
.env.*.local
.env.docker
.env.pre
.env.pro

# ===================================================================
# Backend Build Output
# ===================================================================
dist/
build/
*.js.map
*.ts.map

# ===================================================================
# Frontend Build Output (Angular)
# ===================================================================
frontend/dist/
frontend/build/
.angular/
browser/

# ===================================================================
# Database Files (Sensitive)
# ===================================================================
*.db
*.sqlite
*.sqlite3
database/*.db
database/*.db-*
avales.db
avales.db-*

# Database backups (store separately if needed)
database/*.bak
database/*.backup

# ===================================================================
# IDE / Editor
# ===================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ===================================================================
# OS
# ===================================================================
.DS_Store
Thumbs.db

# ===================================================================
# Docker (volumes can be large)
# ===================================================================
caddy_data/
caddy_config/
docker-compose.override.yml

# ===================================================================
# Credentials & Secrets (NEVER COMMIT)
# ===================================================================
credentials/
secrets/
*.key
*.pem
*.p12
*.pfx
*.pem
duckdns-token.txt

# ===================================================================
# Logs
# ===================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===================================================================
# Temporary Files
# ===================================================================
tmp/
temp/
*.tmp

# ===================================================================
# OS-specific backup files
# ===================================================================
*.bak
*.backup
*.old
*~

# ===================================================================
# Tests Coverage
# ===================================================================
coverage/
.nyc_output/

# ===================================================================
# System Files
# ===================================================================
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes
ehthumbs.db

# ===================================================================
# Angular specific
# ===================================================================
frontend/.angular/cache/
frontend/dist/
karma-coverage/

# ===================================================================
# Python (if migration scripts are added later)
# ===================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/

# ===================================================================
# Notes (Development Only)
# ===================================================================
NOTES.md
NOTES.txt
TODO.md
WIP/

# ===================================================================
# Backup DB exports
# ===================================================================
*.sql.bak
*.sql.backup
avales.db.bak-*
